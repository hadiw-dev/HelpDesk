# =========================================
# Environment / secrets
# =========================================
# Real secrets live in `dotnet user-secrets` (outside the repo) or a vault — never here.
.env
.env.*.local
.env.local
*.pfx
*.key
secrets.json

# .env.development is intentionally tracked: it only holds a non-secret local API base URL.
!frontend/.env.development

# =========================================
# Logs
# =========================================
# Serilog file sink output — contains real request data (tokens, emails, SQL params) at runtime.
backend/src/HelpDesk.Api/Logs/
*.log

