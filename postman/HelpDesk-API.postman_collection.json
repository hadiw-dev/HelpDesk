          "name": "Get Assignment History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/assignments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "assignments"]
            }
          }
        },
