    {
      "name": "Tickets",
      "item": [
        {
          "name": "Search Tickets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets?page=1&pageSize=20&sortBy=createdAt&sortDescending=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets"],
              "query": [
                { "key": "searchTerm", "value": "", "disabled": true },
                { "key": "categoryId", "value": "{{categoryId}}", "disabled": true },
                { "key": "priorityId", "value": "{{priorityId}}", "disabled": true },
                { "key": "statusId", "value": "{{statusId}}", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortDescending", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Create Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('ticketId', body.id);",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"title\": \"Printer not working on 3rd floor\",\n  \"description\": \"The HP printer near the east stairwell is jammed and shows an error light.\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"priorityId\": \"{{priorityId}}\",\n  \"dueDate\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/tickets", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tickets"] }
          }
        },
        {
          "name": "Get Ticket By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tickets", "{{ticketId}}"] }
          }
        },
        {
          "name": "Get Ticket History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/history",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "history"]
            }
          }
        },
        {
          "name": "Update Ticket",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"title\": \"Printer not working on 3rd floor (updated)\",\n  \"description\": \"Still jammed after clearing the tray — needs a technician.\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"priorityId\": \"{{priorityId}}\",\n  \"statusId\": \"{{statusId}}\",\n  \"dueDate\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tickets", "{{ticketId}}"] }
          }
        },
        {
          "name": "Assign Ticket (Agent+ only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"assignedToUserId\": \"{{agentId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/assign", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tickets", "{{ticketId}}", "assign"] }
          }
        },
        {
          "name": "Auto-Assign Ticket (round robin, Agent+ only)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/auto-assign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "auto-assign"]
            }
          }
        },
