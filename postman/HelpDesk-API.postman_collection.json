            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/restore", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tickets", "{{ticketId}}", "restore"] }
          }
        },
