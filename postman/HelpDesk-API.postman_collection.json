{
  "info": {
    "name": "HelpDesk API",
    "description": "IT Help Desk & Ticketing Management System — complete API collection covering Auth, Tickets, Assignments, Comments, Attachments, Notifications, Dashboard/Reports, and Admin (Users, Lookups, Activity Logs, Settings).\n\nSetup:\n1. Import the companion environment file `HelpDesk-Local.postman_environment.json` and select it.\n2. Run `Auth > Register` (or `Auth > Login` if the account already exists) once — its test script stores `accessToken` / `refreshToken` / `userId` as collection variables automatically, and every other request is authorized via a collection-level Bearer token that reads `{{accessToken}}`.\n3. Run `Lookups > Get Categories` and `Get Priorities` once to populate `{{categoryId}}` / `{{priorityId}}`, then `Tickets > Create Ticket` to populate `{{ticketId}}`.\n4. Admin-only requests (the `Admin - *` folders) need a token for a user in the Admin role — either promote the registered test account directly in the database, or log in as an existing Admin account and re-run Login.\n\nAll endpoints are versioned under `/api/v1`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5019" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "ticketId", "value": "" },
    { "key": "attachmentId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "priorityId", "value": "" },
    { "key": "statusId", "value": "" },
    { "key": "agentId", "value": "" },
    { "key": "adminUserId", "value": "" },
    { "key": "resetToken", "value": "" },
    { "key": "notificationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "pm.collectionVariables.set('userId', body.user.id);",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns an access token', () => pm.expect(body.accessToken).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"{{$randomEmail}}\",\n  \"password\": \"Passw0rd!123\",\n  \"confirmPassword\": \"Passw0rd!123\",\n  \"firstName\": \"{{$randomFirstName}}\",\n  \"lastName\": \"{{$randomLastName}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "pm.collectionVariables.set('userId', body.user.id);",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"user@helpdesk.local\",\n  \"password\": \"Passw0rd!123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "Login - Wrong Password (expect 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"user@helpdesk.local\",\n  \"password\": \"DefinitelyWrong!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "refresh-token"] }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/profile", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "profile"] }
          }
        },
