              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"Name\",\n  \"department\": \"IT\",\n  \"jobTitle\": \"Support Specialist\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/profile", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "profile"] }
          }
        },
