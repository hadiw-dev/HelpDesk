          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "comments"]
            }
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"content\": \"Confirmed on-site — replacement part ordered.\",\n  \"isInternal\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "comments"]
            }
          }
        },
        {
          "name": "Get Attachments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/attachments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "attachments"]
            }
          }
        },
        {
          "name": "Upload Attachment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('attachmentId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": [] }]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/attachments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "attachments"]
            },
            "description": "Select a real file for the 'file' form field before sending — magic-byte content validation runs server-side, so the file's actual bytes must match its extension (e.g. a real PDF for a .pdf upload)."
          }
        },
        {
          "name": "Download Attachment",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/attachments/{{attachmentId}}/download",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "attachments", "{{attachmentId}}", "download"]
            }
          }
        },
        {
          "name": "Delete Attachment",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/attachments/{{attachmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "attachments", "{{attachmentId}}"]
            }
          }
        },
