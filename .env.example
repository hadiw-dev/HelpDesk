# Copy this file to `.env` (same directory as docker-compose.yml) before running `docker compose up`.
# `.env` is gitignored — real secrets never get committed; only this placeholder template does.

# SQL Server `sa` password. Must satisfy SQL Server's complexity policy: 8+ characters, with at
# least 3 of (uppercase, lowercase, digit, symbol).
MSSQL_SA_PASSWORD=Ch@ngeMe123!

# Signing key for JWTs issued by the API. Must be at least 32 bytes (ASCII characters) — the app
# fails fast at startup otherwise (see Program.cs's Jwt:SecretKey validation, added in Phase 7).
# Generate a real one with: openssl rand -base64 48
JWT_SECRET_KEY=docker-local-demo-signing-key-please-change-me-1234567890
